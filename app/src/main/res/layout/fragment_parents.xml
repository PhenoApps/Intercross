<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/parentDivider"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/frag_parents_tb"
            android:layout_height="wrap_content"
            android:layout_width="0dp"
            android:background="?attr/colorPrimary"
            android:gravity="center_vertical|start"
            app:menu="@menu/parents_toolbar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Light">

            <TextView
                android:id="@+id/frag_parents_toolbar_count_tv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:gravity="start"
                android:textColor="#FFFFFF"
                android:textAppearance="?attr/textAppearanceHeadline5"
                tools:text="8"/>

        </androidx.appcompat.widget.Toolbar>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/filter_chip_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            app:singleSelection="true"
            app:selectionRequired="true"
            app:layout_constraintTop_toBottomOf="@id/frag_parents_tb"
            app:layout_constraintStart_toStartOf="parent">

            <com.google.android.material.chip.Chip
                android:id="@+id/filter_female"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/female"
                android:checked="true"
                app:chipIcon="@drawable/ic_female_black_24dp"
                app:chipIconSize="18dp"/>

            <com.google.android.material.chip.Chip
                android:id="@+id/filter_male"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/male"
                app:chipIcon="@drawable/ic_male_black_24dp"
                app:chipIconSize="18dp"/>

        </com.google.android.material.chip.ChipGroup>

        <CheckBox
            android:id="@+id/frag_parents_select_all_cb"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="16dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/filter_chip_group"
            app:layout_constraintBottom_toBottomOf="@id/filter_chip_group"/>

        <TextView
            android:id="@+id/no_data_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/parents_table_empty"
            android:textSize="16sp"
            android:visibility="gone"
            android:textColor="?android:attr/textColorSecondary"
            app:layout_constraintTop_toBottomOf="@id/filter_chip_group"
            app:layout_constraintBottom_toTopOf="@id/bottom_nav_bar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/femaleRecycler"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:paddingBottom="176dp"
            android:visibility="visible"
            app:layout_constraintBottom_toTopOf="@id/bottom_nav_bar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/filter_chip_group"
            tools:listitem="@layout/list_item_selectable_parent_row" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/maleRecycler"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="8dp"
            android:clipToPadding="false"
            android:paddingBottom="176dp"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/bottom_nav_bar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/filter_chip_group"
            tools:listitem="@layout/list_item_selectable_parent_row" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/frag_parents_delete_fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:contentDescription="@string/menu_parents_delete_title"
            android:visibility="gone"
            app:backgroundTint="@color/colorAccent"
            app:fabSize="normal"
            app:layout_constraintBottom_toTopOf="@id/frag_parents_print_fab"
            app:layout_constraintEnd_toEndOf="parent"
            app:maxImageSize="20dp"
            app:srcCompat="@drawable/ic_delete"
            app:tint="@android:color/white"
            tools:visibility="visible" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/frag_parents_print_fab"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:contentDescription="@string/menu_parents_print_title"
            android:visibility="gone"
            app:backgroundTint="?attr/colorAccent"
            app:fabSize="normal"
            app:layout_constraintBottom_toTopOf="@id/frag_parents_new_parent_btn"
            app:layout_constraintEnd_toEndOf="parent"
            app:maxImageSize="20dp"
            app:srcCompat="@drawable/ic_cross_print"
            app:tint="@android:color/white"
            tools:visibility="visible" />

        <ImageButton
            android:id="@+id/frag_parents_new_parent_btn"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_margin="16dp"
            android:background="@drawable/capture_button_background"
            android:contentDescription="@string/frag_parents_create_parents_btn"
            android:cropToPadding="false"
            android:elevation="5dp"
            android:scaleType="fitCenter"
            app:tint="#ffffff"
            app:layout_constraintBottom_toTopOf="@id/bottom_nav_bar"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/ic_add_black_24dp" />

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav_bar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:menu="@menu/menu_bot_nav"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>